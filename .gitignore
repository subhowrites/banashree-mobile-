# .gitignore - इन files को GitHub पर मत भेजो

# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.production

# Netlify build
.netlify/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.sublime-*

# Temp files
*.tmp
*.temp